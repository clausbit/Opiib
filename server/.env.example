# Environment
NODE_ENV=development

# Server Configuration
PORT=3001
CLIENT_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/casino

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=your_bot_username

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Game Configuration
HOUSE_EDGE=0.05
MIN_BET=1
MAX_BET=1000
STARTING_BALANCE=100

# Payment Providers
CRYPTO_PROVIDER_API_KEY=your-crypto-provider-api-key
CRYPTO_PROVIDER_SECRET=your-crypto-provider-secret

# TON Wallet
TON_WALLET_ADDRESS=your-ton-wallet-address
TON_API_KEY=your-ton-api-key

# Monitoring
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# Redis (Optional for session storage)
REDIS_URL=redis://localhost:6379

# Webhook URLs
PAYMENT_WEBHOOK_URL=https://your-domain.com/api/payment/webhook
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/telegram/webhook